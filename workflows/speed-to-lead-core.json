    {
      "id": "node-owner-format",
      "name": "Code: Format Owner Notification",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2000, 220],
      "parameters": {
        "jsCode": "// NOTIF-01, NOTIF-02: Owner notification with tel: one-tap callback link\nconst name = $json.name || 'Prospect';\nconst request = $json.request || '';\nconst phone = $json.phone || null;\nconst email = $json.email || 'non fourni';\nconst claudeMsg = $json.claude_message || '';\n\n// Build owner request summary for WhatsApp template\nlet ownerRequestSummary;\nif (phone) {\n  ownerRequestSummary = `\"${request.substring(0, 60)}\" — Appeler: ${phone}`;\n} else {\n  ownerRequestSummary = `\"${request.substring(0, 60)}\" — Email: ${email} (Pas de tél)`;\n}\n\n// Truncate to 320 chars max\nownerRequestSummary = ownerRequestSummary.substring(0, 320);\n\n// Carry all fields forward for potential future nodes\nreturn [{\n  json: {\n    lead_id: $json.lead_id,\n    name,\n    phone,\n    email,\n    request,\n    claude_message: claudeMsg,\n    owner_request_summary: ownerRequestSummary,\n    client_config: $json.client_config\n  }\n}];"
      }
    },

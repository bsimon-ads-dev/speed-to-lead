        "htmlContent": "=<p>{{ $json.claude_message }}</p><br><p style=\"color:#666;font-size:12px;\">{{ $json.client_config.business_name }} \u2014 Vous pouvez r\u00e9pondre \u00e0 cet email ou appeler directement.</p>"

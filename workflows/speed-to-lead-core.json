        "fromEmail": "={{ $json.client_config.brevo_sender_email }}",
        "toEmail": "={{ $json.email }}",
        "subject": "=Votre demande — {{ $json.client_config.business_name }}",
        "htmlContent": "=<p>{{ $json.claude_message }}</p><br><p style=\"color:#666;font-size:12px;\">{{ $json.client_config.business_name }} — Vous pouvez répondre à cet email ou appeler directement.</p>"

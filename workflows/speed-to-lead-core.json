      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [460, 300],
      "parameters": {
        "jsCode": "const staticData = $getWorkflowStaticData('global');\nconst input = $input.first().json;\n\nstaticData.lastLead = {\n  ...input,\n  client_config: input.client_config,\n  logged_at: new Date().toISOString()\n};\n\nreturn { json: input };"
      }
    },
    {
      "id": "node-dedup",
      "name": "Remove Duplicates: lead_id",
      "type": "n8n-nodes-base.removeDuplicates",
      "typeVersion": 1,
      "position": [680, 300],
      "parameters": {
        "operation": "removeItemsSeenInPreviousExecutions",

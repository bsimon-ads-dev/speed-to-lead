    {
      "id": "node-biz-hours",
      "name": "Code: Business Hours Check",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2660, 220],
      "parameters": {
        "jsCode": "// NOTIF-03: Gate follow-up on business hours\n// Reference: n8n Luxon cookbook — $now.setZone(), .hour, .weekday\nconst now = $now.setZone('Europe/Paris');\nconst hour = now.hour;       // 0-23\nconst weekday = now.weekday; // 1=Mon, 2=Tue, 3=Wed, 4=Thu, 5=Fri, 6=Sat, 7=Sun\n\n// Allow Mon-Sat 08:00-19:59 Paris time\nconst business_hours_ok = (\n  weekday >= 1 &&\n  weekday <= 6 &&\n  hour >= 8 &&\n  hour < 20\n);\n\nconsole.log('Business hours check:', { weekday, hour, business_hours_ok, tz: 'Europe/Paris' });\n\nreturn [{ json: { ...$input.first().json, business_hours_ok } }];"
      }
    },

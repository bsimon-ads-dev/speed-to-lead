          "combinator": "and",
          "conditions": [
            {
              "id": "condition-biz-hours",
              "leftValue": "={{ $json.business_hours_ok }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "true",
                "name": "filter.operator.true"
              }
            }
          ]
        },
        "looseTypeValidation": false
      }
    },
